   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Check GPU"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch\n",
    "\n",
    "device = 'cuda' if torch.cuda.is_available() else 'cpu'\n",
    "if device == 'cuda':\n",
    "    print(f'GPU ready: {torch.cuda.get_device_name(0)}')\n",
    "else:\n",
    "    print('No GPU detected — running on CPU (slower). Enable via Runtime > Change runtime type > T4 GPU')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 3. Load Model\n",
    "\n",
    "| Model | Size | Speed | Accuracy |\n",
    "|-------|------|-------|----------|\n",
    "| `tiny` | 39M | Fastest | Good |\n",
    "| `base` | 74M | Fast | Better |\n",
    "| `small` | 244M | Moderate | Great |\n",
    "| `medium` | 769M | Slow | Excellent |\n",
    "| `large-v3` | 1.5G | Slowest | Best |"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import whisper\n",
    "\n",
    "MODEL_SIZE = 'base'  # change to: tiny | base | small | medium | large-v3\n",
    "\n",
    "print(f'Loading whisper/{MODEL_SIZE} on {device}...')\n",
    "model = whisper.load_model(MODEL_SIZE, device=device)\n",
    "print(f'Model loaded.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Transcribe: Upload a File"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "from google.colab import files\n",
    "import os\n",
    "\n",
    "print('Upload an audio file (mp3, wav, m4a, ogg, flac, webm):')\n",
    "uploaded = files.upload()\n",
    "\n",
    "audio_path = list(uploaded.keys())[0]\n",
    "print(f'\\nFile received: {audio_path} ({os.path.getsize(audio_path) / 1024:.1f} KB)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "LANGUAGE = None  # None = auto-detect | or set e.g. 'en', 'es', 'fr', 'de', 'ja', 'zh'\n",
    "TASK = 'transcribe'  # 'transcribe' to keep original language | 'translate' to translate to English\n",
    "\n",
    "print('Transcribing...')\n",
    "result = model.transcribe(\n",
    "    audio_path,\n",
    "    language=LANGUAGE,\n",
    "    task=TASK,\n",
    "    verbose=False\n",
    ")\n",
    "\n",
    "detected_lang = result.get('language', 'unknown')\n",
    "transcript = result['text'].strip()\n",
    "\n",
    "print(f'Detected language: {detected_lang}')\n",
    "print(f'\\n--- Transcript ---\\n')\n",
    "print(transcript)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 5. Transcribe: Record from Microphone"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Records audio directly in the browser cell\n",
    "from IPython.display import display, Javascript\n",
    "from google.colab.output import eval_js\n",
    "from base64 import b64decode\n",
    "import io\n",
    "\n",
    "RECORD_SECONDS = 10  # change recording duration here\n",
    "\n",
    "js = Javascript(f'''\n",
    "async function recordAudio() {{\n",
    "  const div = document.createElement('div');\n",
    "  div.style.cssText = 'padding:16px;background:#111;border:1px solid #00ff9d;border-radius:8px;color:#00ff9d;font-family:monospace;margin:8px 0';\n",
    "  div.innerText = 'Recording for {RECORD_SECONDS}s... speak now';\n",
    "  document.querySelector('#output-area').appendChild(div);\n",
    "\n",
    "  const stream = await navigator.mediaDevices.getUserMedia({{ audio: true }});\n",
    "  const recorder = new MediaRecorder(stream);\n",
    "  const chunks = [];\n",
    "  recorder.ondataavailable = e => chunks.push(e.data);\n",
    "  recorder.start();\n",
    "\n",
    "  await new Promise(r => setTimeout(r, {RECORD_SECONDS * 1000}));\n",
    "  recorder.stop();\n",
    "  stream.getTracks().forEach(t => t.stop());\n",
    "\n",
    "  await new Promise(r => recorder.onstop = r);\n",
    "  const blob = new Blob(chunks, {{ type: 'audio/webm' }});\n",
    "  const reader = new FileReader();\n",
    "  reader.readAsDataURL(blob);\n",
    "  await new Promise(r => reader.onloadend = r);\n",
    "\n",
    "  div.innerText = 'Recording complete.';\n",
    "  return reader.result.split(',')[1];\n",
    "}}\n",
    "recordAudio()\n",
    "''')\n",
    "\n",
    "display(js)\n",
    "audio_b64 = eval_js('recordAudio()')\n",
    "audio_bytes = b64decode(audio_b64)\n",
    "\n",
    "mic_path = '/tmp/mic_recording.webm'\n",
    "with open(mic_path, 'wb') as f:\n",
    "    f.write(audio_bytes)\n",
    "\n",
    "print(f'Saved {len(audio_bytes) / 1024:.1f} KB — transcribing...')\n",
    "\n",
    "result = model.transcribe(mic_path, verbose=False)\n",
    "transcript = result['text'].strip()\n",
    "print(f'\\n--- Transcript ---\\n{transcript}')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 6. Export Transcript"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- Plain text export ---\n",
    "txt_path = '/tmp/transcript.txt'\n",
    "with open(txt_path, 'w') as f:\n",
    "    f.write(transcript)\n",
    "\n",
    "files.download(txt_path)\n",
    "print('Downloaded: transcript.txt')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# --- SRT subtitle export ---\n",
    "def format_timestamp(seconds):\n",
    "    h = int(seconds // 3600)\n",
    "    m = int((seconds % 3600) // 60)\n",
    "    s = int(seconds % 60)\n",
    "    ms = int((seconds % 1) * 1000)\n",
    "    return f'{h:02d}:{m:02d}:{s:02d},{ms:03d}'\n",
    "\n",
    "srt_lines = []\n",
    "for i, seg in enumerate(result['segments'], 1):\n",
    "    srt_lines.append(str(i))\n",
    "    srt_lines.append(f\"{format_timestamp(seg['start'])} --> {format_timestamp(seg['end'])}\")\n",
    "    srt_lines.append(seg['text'].strip())\n",
    "    srt_lines.append('')\n",
    "\n",
    "srt_path = '/tmp/transcript.srt'\n",
    "with open(srt_path, 'w') as f:\n",
    "    f.write('\\n'.join(srt_lines))\n",
    "\n",
    "files.download(srt_path)\n",
    "print('Downloaded: transcript.srt')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 7. Gradio UI (Optional)\n",
    "Launches a full web interface inside Colab — upload files, pick model size, choose language, and copy or download the result."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import gradio as gr\n",
    "import whisper\n",
    "import torch\n",
    "\n",
    "_models = {}\n",
    "\n",
    "def get_model(size):\n",
    "    if size not in _models:\n",
    "        _models[size] = whisper.load_model(size, device=device)\n",
    "    return _models[size]\n",
    "\n",
    "def transcribe_ui(audio, model_size, language, task):\n",
    "    if audio is None:\n",
    "        return 'No audio provided.', ''\n",
    "    m = get_model(model_size)\n",
    "    lang = None if language == 'Auto-detect' else language\n",
    "    result = m.transcribe(audio, language=lang, task=task, verbose=False)\n",
    "    detected = result.get('language', 'unknown')\n",
    "    return result['text'].strip(), f'Detected language: {detected} | Segments: {len(result[\"segments\"])}'\n",
    "\n",
    "LANGUAGES = [\n",
    "    'Auto-detect', 'en', 'es', 'fr', 'de', 'it', 'pt', 'nl',\n",
    "    'ja', 'zh', 'ko', 'ar', 'hi', 'ru', 'tr', 'pl', 'sv'\n",
    "]\n",
    "\n",
    "with gr.Blocks(\n",
    "    title='Deep Site // Whisper Node',\n",
    "    theme=gr.themes.Base(\n",
    "        primary_hue='green',\n",
    "        neutral_hue='slate'\n",
    "    )\n",
    ") as demo:\n",
    "    gr.Markdown('# Deep Site // Whisper Node\\n> GPU-accelerated speech transcription')\n",
    "\n",
    "    with gr.Row():\n",
    "        with gr.Column():\n",
    "            audio_input = gr.Audio(\n",
    "                sources=['upload', 'microphone'],\n",
    "                type='filepath',\n",
    "                label='Audio Input'\n",
    "            )\n",
    "            with gr.Row():\n",
    "                model_dd = gr.Dropdown(\n",
    "                    choices=['tiny', 'base', 'small', 'medium', 'large-v3'],\n",
    "                    value='base',\n",
    "                    label='Model'\n",
    "                )\n",
    "                lang_dd = gr.Dropdown(\n",
    "                    choices=LANGUAGES,\n",
    "                    value='Auto-detect',\n",
    "                    label='Language'\n",
    "                )\n",
    "                task_dd = gr.Dropdown(\n",
    "                    choices=['transcribe', 'translate'],\n",
    "                    value='transcribe',\n",
    "                    label='Task'\n",
    "                )\n",
    "            run_btn = gr.Button('Transcribe', variant='primary')\n",
    "\n",
    "        with gr.Column():\n",
    "            output_text = gr.Textbox(\n",
    "                label='Transcript',\n",
    "                lines=12,\n",
    "                show_copy_button=True\n",
    "            )\n",
    "            meta_text = gr.Textbox(label='Info', lines=1, interactive=False)\n",
    "\n",
    "    run_btn.click(\n",
    "        fn=transcribe_ui,\n",
    "        inputs=[audio_input, model_dd, lang_dd, task_dd],\n",
    "        outputs=[output_text, meta_text]\n",
    "    )\n",
    "\n",
    "demo.launch(share=True, debug=False)"
   ]
  },
